# Copy this file to .env before running Docker.

OPENEMR_IMAGE=openemr/openemr:8.0.0.3
OPENEMR_HTTP_PORT=8080

MYSQL_ROOT_PASSWORD=rootpass
OPENEMR_DB_NAME=openemr
OPENEMR_DB_USER=openemr
OPENEMR_DB_PASSWORD=openemr

OPENEMR_ADMIN_USER=admin
OPENEMR_ADMIN_PASSWORD=pass

# Jitsi test config. Public meet.jit.si is fine for development smoke tests,
# but production should use a controlled Jitsi domain with auth/token policy.
MEDSOV_TELEHEALTH_JITSI_DOMAIN=meet.jit.si
MEDSOV_TELEHEALTH_BASE_URL=https://meet.jit.si
MEDSOV_TELEHEALTH_JITSI_EXTERNAL_API=https://meet.jit.si/external_api.js
